#include <iostream>
#include <cstring>
using namespace std;

class Person {
private:
    char name[50];   // fixed-size char array for name
    long long studentID;
    int age;

public:
    void init(const char* inputName, long long id, int a) {
        strcpy(name, inputName);   // copy string into name
        studentID = id;
        age = a;
    }

    void printStudentInfo() {
        cout << "Name: " << name
             << ", ID: " << studentID
             << ", Age: " << age << endl;
    }

    long long getID() { return studentID; }
    int getAge() { return age; }
    const char* getName() { return name; }

    friend void personSwap(Person &p1, Person &p2);
};

void personSwap(Person &p1, Person &p2) {
    Person temp;
    temp.init(p1.getName(), p1.getID(), p1.getAge());
    p1.init(p2.getName(), p2.getID(), p2.getAge());
    p2.init(temp.getName(), temp.getID(), temp.getAge());
}

int main() {
    Person p1, p2;
    p1.init("Alice", 2026312345, 20);
    p2.init("Bob", 2019354321, 25);

    cout << "Before Swap:" << endl;
    p1.printStudentInfo();
    p2.printStudentInfo();

    personSwap(p1, p2);

    cout << "After Swap:" << endl;
    p1.printStudentInfo();
    p2.printStudentInfo();

    return 0;
}
